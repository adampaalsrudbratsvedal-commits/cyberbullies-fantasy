{
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "routePrefix": "/_/backend",
      "entrypoint": "api/index.py"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/_/backend/api/:path*" }
  ],
  "crons": [
    {
      "path": "/api/fantasy/sync-squads-cron",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/league/sync-cron",
      "schedule": "0 */2 * * *"
    }
  ]
}
